# =====================================================================
# AvoRAG — configuración. Copia este archivo a `.env` y ajústalo.
#   cp .env.example .env        (o en PowerShell: Copy-Item .env.example .env)
# NUNCA subas `.env` al repo (ya está en .gitignore).
# =====================================================================

# --- Entorno general ---
AVORAG_ENV=dev                       # dev | staging | prod
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false                       # true en prod (logs estructurados JSON)

# --- Base de datos (Postgres + pgvector) -----------------------------
# Opción A (recomendada ahora, sin Docker): crea una base gratis en Neon
#   (https://neon.tech) o Supabase y pega aquí su connection string.
# Opción B (local con Docker): usa la URL del docker-compose incluido:
#   postgresql+psycopg://avorag:avorag@localhost:5432/avorag
DATABASE_URL=postgresql+psycopg://avorag:avorag@localhost:5432/avorag

# Dimensión del vector de embeddings. DEBE coincidir con el modelo elegido:
#   bge-m3 -> 1024 | text-embedding-3-small -> 1536 | text-embedding-3-large -> 3072
# Cambiarla implica re-indexar el corpus (re-embed). Ver docs/adr/0004.
EMBEDDING_DIM=1024

# --- Proveedor de LLM (generación) -----------------------------------
# ollama (gratis, local, por defecto) | anthropic (demo/venta) | openai
LLM_PROVIDER=ollama
# Calidad vs velocidad (mismo proveedor, solo cambia el modelo):
#   qwen2.5:7b-instruct  -> mejor calidad (números de evaluación medidos con este).
#   qwen2.5:3b-instruct  -> ~2-7x más rápido y cabe holgado en 8 GB de VRAM (generación + jueces).
LLM_MODEL=qwen2.5:7b-instruct
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=700
# Solo si LLM_PROVIDER=anthropic:
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Solo si LLM_PROVIDER=openai:
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini

# --- Proveedor de embeddings -----------------------------------------
# ollama (local, por defecto) | openai | local (sentence-transformers GPU)
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=bge-m3               # para ollama: requiere `ollama pull bge-m3`
# Para EMBEDDING_PROVIDER=openai usa OPENAI_API_KEY de arriba y EMBEDDING_MODEL=text-embedding-3-small

# --- Reranker (opcional; mejora la calidad de recuperación) ----------
# none (por defecto) | cohere | local (FlagEmbedding GPU, requiere `uv sync --extra local`)
RERANK_PROVIDER=none
RERANK_MODEL=BAAI/bge-reranker-v2-m3
COHERE_API_KEY=

# --- Ollama (servidor local) -----------------------------------------
OLLAMA_HOST=http://localhost:11434

# --- Recuperación / RAG ----------------------------------------------
RETRIEVAL_TOP_K=20                   # candidatos antes del reranking
FINAL_TOP_K=6                        # chunks que ve el LLM
RRF_K=60                             # constante de Reciprocal Rank Fusion
# Umbral sobre el score RRF del mejor candidato (no es 0-1; depende de RRF_K y del nº de
# listas). 0.0 = desactivado (solo abstiene si NO hay candidatos). Para activar abstención
# por baja recuperación, sube gradualmente (p.ej. 0.01-0.03) midiendo en el golden set.
MIN_RETRIEVAL_SCORE=0.0

# --- Multi-tenant ----------------------------------------------------
DEFAULT_TENANT=demo                  # ruta A usa un solo tenant

# --- Guardarraíles ---------------------------------------------------
FAITHFULNESS_JUDGE=true              # LLM-judge de fidelidad por respuesta
DOSE_GUARDRAIL=true                  # bloquea dosis no rastreables a fuente
COUNTRY=CO                           # geofiltro por país (CO | ES)

# --- API -------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000

# --- Observabilidad (opcional) ---------------------------------------
SENTRY_DSN=
